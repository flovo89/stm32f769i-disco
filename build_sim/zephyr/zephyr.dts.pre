/ {
 arduino_header: connector {
  compatible = "arduino-header-r3";
  #gpio-cells = <2>;
  gpio-map-mask = <0xffffffff 0xffffffc0>;
  gpio-map-pass-thru = <0 0x3f>;
  gpio-map = <0 0 &gpioa 6 0>,
      <1 0 &gpioa 4 0>,
      <2 0 &gpioc 2 0>,
      <3 0 &gpiof 10 0>,
      <4 0 &gpiof 8 0>,
      <5 0 &gpiof 9 0>,
      <6 0 &gpioc 7 0>,
      <7 0 &gpioc 6 0>,
      <8 0 &gpioj 1 0>,
      <9 0 &gpiof 6 0>,
      <10 0 &gpioj 0 0>,
      <11 0 &gpioc 8 0>,
      <12 0 &gpiof 7 0>,
      <13 0 &gpioj 3 0>,
      <14 0 &gpioj 4 0>,
      <15 0 &gpioh 6 0>,
      <16 0 &gpioa 11 0>,
      <17 0 &gpiob 15 0>,
      <18 0 &gpiob 14 0>,
      <19 0 &gpioa 12 0>,
      <20 0 &gpiob 9 0>,
      <21 0 &gpiob 8 0>;
 };
};

arduino_spi: &spi2 {};
